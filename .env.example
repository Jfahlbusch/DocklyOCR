# Database
DATABASE_URL=sqlite:////data/ocr.db

# Redis (for ARQ job queue)
REDIS_URL=redis://redis:6379/0

# Ollama (runs on host, bound to 127.0.0.1 only)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=glm-ocr
OLLAMA_REQUEST_TIMEOUT_S=120

# Admin UI
ADMIN_USERNAME=admin
# bcrypt hash - generate via: python scripts/hash_password.py '<your-password>'
ADMIN_PASSWORD_HASH=
# 32+ random bytes, e.g. python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Storage
STORAGE_DIR=/data/storage

# CORS (comma-separated origins, leave empty to disable)
ALLOWED_ORIGINS=

# Upload limits
MAX_UPLOAD_MB=100

# Result retention
RESULT_TTL_DAYS=30

# Rate limit per API key (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# Sync OCR timeout (seconds) — async should be used for larger files
SYNC_TIMEOUT_S=300
