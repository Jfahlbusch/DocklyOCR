# Database
DATABASE_URL=sqlite:////data/ocr.db

# Redis (for ARQ job queue)
REDIS_URL=redis://redis:6379/0

# ── OCR backend ─────────────────────────────────────────────────────────────
# Two supported backends, selected via OLLAMA_USE_OPENAI_API:
#
#   vLLM (recommended for GPU):
#     OLLAMA_URL=http://<gpu-host>:8000
#     OLLAMA_MODEL=qwen2.5-vl-7b       (must match --served-model-name)
#     OLLAMA_USE_OPENAI_API=true       (uses /v1/chat/completions)
#
#   Ollama (CPU-friendly fallback):
#     OLLAMA_URL=http://host.docker.internal:11434
#     OLLAMA_MODEL=glm-ocr
#     OLLAMA_USE_OPENAI_API=false      (uses /api/generate)
#
# Variable names are "OLLAMA_*" for historical reasons; values work
# identically for vLLM when OLLAMA_USE_OPENAI_API=true.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-vl-7b
OLLAMA_USE_OPENAI_API=true
OLLAMA_REQUEST_TIMEOUT_S=120

# Admin UI
ADMIN_USERNAME=admin
# bcrypt hash — generate via: python scripts/hash_password.py '<your-password>'
# IMPORTANT for docker-compose: escape every '$' as '$$' in the hash.
ADMIN_PASSWORD_HASH=
# 32+ random bytes, e.g. python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Storage
STORAGE_DIR=/data/storage

# CORS (comma-separated origins, leave empty to disable)
ALLOWED_ORIGINS=

# Upload limits
MAX_UPLOAD_MB=100

# Result retention (days) — cleanup cron deletes older jobs
RESULT_TTL_DAYS=30

# Rate limit per API key (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# Sync OCR timeout (seconds) — async should be used for larger files
SYNC_TIMEOUT_S=300

# ── Scaleway on-demand GPU (optional) ───────────────────────────────────────
# Set when the OCR backend runs on a separate GPU instance that should be
# powered off when idle. Worker auto-starts the instance on job arrival.
# Leave empty when the backend is always-on or on the same machine.
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_GPU_SERVER_ID=
SCW_GPU_ZONE=fr-par-2
